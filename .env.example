# Database
DATABASE_URL="postgresql://user:password@host:port/database"

# Google OAuth (required for Google sign-in)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# Legal/compliance placeholders shown on Privacy Policy, Impressum, and Terms pages
NEXT_PUBLIC_LEGAL_COMPANY_NAME="Your legal company or project owner name"
NEXT_PUBLIC_LEGAL_OWNER_NAME="Responsible legal owner"
NEXT_PUBLIC_LEGAL_ADDRESS="Street 1, 12345 City, Germany"
NEXT_PUBLIC_LEGAL_EMAIL="legal@example.com"
NEXT_PUBLIC_LEGAL_PHONE="+49 ..."
NEXT_PUBLIC_LEGAL_VAT_ID="DE..."
NEXT_PUBLIC_PRIVACY_EMAIL="privacy@example.com"
NEXT_PUBLIC_DATA_PROTECTION_AUTHORITY="Responsible data protection supervisory authority"
NEXT_PUBLIC_HOSTING_PROVIDER="Hosting provider name"
NEXT_PUBLIC_HOSTING_REGION="EU"
NEXT_PUBLIC_ANALYTICS_ENABLED="false"
